# LTFS LTO-6b — TrueNAS Optiplex 7010 (segundo drive, host7)
LTFS_BIN=/var/db/ltfs-patched/bin/ltfs
LTFS_DEVICE_RESOLVER=/var/db/ltfs-tools/lto6b-resolve-device
LTFS_DEVICE=/dev/sg2
LTFS_TAPE_DEVICE=/dev/nst0
LTFS_MOUNT_POINT=/mnt/tape/lto6b
LTFS_SERVICE=ltfs-lto6b.service
LTFS_ORCH_LOCK=/run/lock/ltfs-orchestrator-b.lock
LTFS_LEGACY_SELFHEAL_SCRIPT=/var/db/ltfs-tools/ltfs-selfheal-remount.sh
LTFS_WORKDIR=/var/lib/ltfs/work-b
LTFS_LOGFILE=/var/log/ltfs-lto6b.log
LTFS_PIDFILE=/run/ltfs-lto6b.pid
LTFS_SUSPEND_STATE_FILE=/run/ltfs-recovery/suspended-units-b.json
