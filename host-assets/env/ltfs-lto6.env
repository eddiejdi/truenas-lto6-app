# LTFS LTO-6 — TrueNAS Optiplex 7010
# Tape drive: HP Ultrium 6-SCSI via QLogic ISP2532 FC HBA
LTFS_BIN=/var/db/ltfs-patched/bin/ltfs
LTFS_DEVICE=/dev/sg4
LTFS_TAPE_DEVICE=/dev/nst1
LTFS_MOUNT_POINT=/mnt/tape/lto6
LTFS_SERVICE=ltfs-lto6.service
LTFS_ORCH_LOCK=/run/lock/ltfs-orchestrator.lock
LTFS_LEGACY_SELFHEAL_SCRIPT=/var/db/ltfs-tools/ltfs-selfheal-remount.sh
LTFS_WORKDIR=/var/lib/ltfs/work
LTFS_LOGFILE=/var/log/ltfs-lto6.log
LTFS_PIDFILE=/run/ltfs-lto6.pid
